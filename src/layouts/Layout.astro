---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description = 'Novlify - 副業・投資・旅行・グルメの本音情報', image } = Astro.props;
const adsenseId = import.meta.env.PUBLIC_ADSENSE_ID;
const ogImage = image || 'https://cdn.pixabay.com/photo/2016/11/29/08/41/apple-1868496_1280.jpg';
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="8tviLQ32ZkQ10FSGE-EyTjTaJrhARNtfuMRDuaBYMYA" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.ico" />
    <!-- Noto Sans JP (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {adsenseId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
        crossorigin="anonymous"
      ></script>
    )}
    <slot name="head" />

    <!-- JSON-LD 構造化データ (WebSite + BreadcrumbList) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://novlify.jp/#website",
          "url": "https://novlify.jp/",
          "name": "Novlify",
          "description": "副業・投資・旅行・グルメの本音情報をお届けするブログ",
          "inLanguage": "ja",
          "publisher": {
            "@type": "Person",
            "name": "Nori",
            "url": "https://novlify.jp/about"
          },
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://novlify.jp/?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://novlify.jp/#organization",
          "name": "Novlify",
          "url": "https://novlify.jp/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://novlify.jp/favicon.svg"
          },
          "sameAs": []
        }
      ]
    })} />

    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: #f7f7f7;
        color: #333;
        font-family: 'Noto Sans JP', 'Hiragino Sans', 'Hiragino Kaku Gothic ProN',
          Meiryo, sans-serif;
        font-size: 16px;
        line-height: 1.8;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      a { color: inherit; }
      img { max-width: 100%; height: auto; }

      /* ヘッダー */
      .site-header {
        background: #fff;
        border-bottom: 3px solid #f59e0b;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }
      .site-header__inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 20px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .site-logo {
        font-size: 1.4rem;
        font-weight: 900;
        text-decoration: none;
        color: #1a1a1a;
        letter-spacing: 0.05em;
      }
      .site-logo span { color: #f59e0b; }
      .site-nav { display: flex; gap: 24px; }
      .site-nav a {
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        color: #555;
        transition: color 0.2s;
      }
      .site-nav a:hover { color: #f59e0b; }

      /* メイン */
      .site-main {
        flex: 1;
        max-width: 1080px;
        margin: 0 auto;
        padding: 32px 20px;
        width: 100%;
      }

      /* フッター */
      .site-footer {
        background: #1a1a1a;
        color: #aaa;
        margin-top: auto;
      }
      .site-footer__inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 32px 20px;
      }
      .site-footer__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 20px;
      }
      .site-footer__logo {
        font-size: 1.2rem;
        font-weight: 900;
        color: #fff;
        text-decoration: none;
      }
      .site-footer__logo span { color: #f59e0b; }
      .site-footer__nav {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
      }
      .site-footer__nav a {
        font-size: 0.85rem;
        text-decoration: none;
        color: #aaa;
        transition: color 0.2s;
      }
      .site-footer__nav a:hover { color: #fff; }
      .site-footer__bottom {
        border-top: 1px solid #333;
        padding-top: 16px;
        font-size: 0.8rem;
        text-align: center;
        line-height: 1.6;
        color: #666;
      }

      /* レスポンシブ */
      @media (max-width: 640px) {
        .site-nav { gap: 14px; }
        .site-nav a { font-size: 0.8rem; }
        .site-main { padding: 20px 14px; }
        .site-footer__top { flex-direction: column; align-items: flex-start; }
      }
    </style>
  </head>
  <body>

    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-logo">Nov<span>lify</span></a>
        <nav class="site-nav">
          <a href="/">ホーム</a>
          <a href="/about">About</a>
          <a href="/privacy-policy">プライバシー</a>
          <a href="/contact">お問い合わせ</a>
        </nav>
      </div>
    </header>

    <main class="site-main">
      {adsenseId && (
        <div style="margin-bottom:24px;text-align:center;">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-client={adsenseId}
            data-ad-slot="AUTO"
            data-ad-format="auto"
            data-full-width-responsive="true"
          ></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      )}

      <slot />

      {adsenseId && (
        <div style="margin-top:32px;text-align:center;">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-client={adsenseId}
            data-ad-slot="AUTO"
            data-ad-format="auto"
            data-full-width-responsive="true"
          ></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      )}
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__top">
          <a href="/" class="site-footer__logo">Nov<span>lify</span></a>
          <nav class="site-footer__nav">
            <a href="/about">About</a>
            <a href="/privacy-policy">プライバシーポリシー</a>
            <a href="/disclaimer">免責事項</a>
            <a href="/contact">お問い合わせ</a>
          </nav>
        </div>
        <div class="site-footer__bottom">
          <p>&copy; {new Date().getFullYear()} Novlify. All rights reserved.</p>
          <p>本サイトはアフィリエイト広告を利用しています。</p>
          <p>Amazonのアソシエイトとして、当メディアは適格販売により収入を得ています。</p>
        </div>
      </div>
    </footer>

  </body>
</html>

---
import { NOINDEX_PATHS } from '../config/seo.ts';

export interface Props {
  title: string;
  description?: string;
  image?: string;
  /** 個別ページで手動 noindex にしたい場合だけ使用。通常は src/config/seo.ts の NOINDEX_PATHS で管理 */
  noindex?: boolean;
}
const { title, description = 'Novlify - 副業・投資・旅行・グルメの本音情報', image, noindex: noindexProp = false } = Astro.props;

// NOINDEX_PATHS に含まれるページは自動で noindex にする
const isAutoNoindex = NOINDEX_PATHS.some(
  (p) => Astro.url.pathname === p || Astro.url.pathname === `${p}/`
);
const noindex = noindexProp || isAutoNoindex;

const adsenseId = import.meta.env.PUBLIC_ADSENSE_ID;
const ogImage = image || 'https://cdn.pixabay.com/photo/2016/11/29/08/41/apple-1868496_1280.jpg';
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="8tviLQ32ZkQ10FSGE-EyTjTaJrhARNtfuMRDuaBYMYA" />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="/favicon.ico" />
    <!-- Noto Sans JP (Google Fonts) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {adsenseId && (
      <script
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseId}`}
        crossorigin="anonymous"
      ></script>
    )}
    <slot name="head" />

    <!-- JSON-LD 構造化データ (WebSite + BreadcrumbList) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "WebSite",
          "@id": "https://novlify.jp/#website",
          "url": "https://novlify.jp/",
          "name": "Novlify",
          "description": "副業・投資・旅行・グルメの本音情報をお届けするブログ",
          "inLanguage": "ja",
          "publisher": {
            "@type": "Person",
            "name": "Nori",
            "url": "https://novlify.jp/about"
          },
          "potentialAction": {
            "@type": "SearchAction",
            "target": {
              "@type": "EntryPoint",
              "urlTemplate": "https://novlify.jp/?q={search_term_string}"
            },
            "query-input": "required name=search_term_string"
          }
        },
        {
          "@type": "Organization",
          "@id": "https://novlify.jp/#organization",
          "name": "Novlify",
          "url": "https://novlify.jp/",
          "logo": {
            "@type": "ImageObject",
            "url": "https://novlify.jp/favicon.svg"
          },
          "sameAs": []
        }
      ]
    })} />

    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: #f7f7f7;
        color: #333;
        font-family: 'Noto Sans JP', 'Hiragino Sans', 'Hiragino Kaku Gothic ProN',
          Meiryo, sans-serif;
        font-size: 16px;
        line-height: 1.8;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      a { color: inherit; }
      img { max-width: 100%; height: auto; }

      /* ヘッダー */
      .site-header {
        background: #fff;
        border-bottom: 3px solid #f59e0b;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      }
      .site-header__inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 20px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .site-logo {
        font-size: 1.4rem;
        font-weight: 900;
        text-decoration: none;
        color: #1a1a1a;
        letter-spacing: 0.05em;
      }
      .site-logo span { color: #f59e0b; }
      .site-nav { display: flex; gap: 24px; align-items: center; }
      .site-nav a {
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        color: #555;
        transition: color 0.2s;
      }
      .site-nav a:hover { color: #f59e0b; }

      /* カテゴリドロップダウン */
      .site-nav__dropdown { position: relative; }
      .site-nav__dropdown-trigger {
        font-size: 0.875rem;
        font-weight: 500;
        color: #555;
        cursor: pointer;
        transition: color 0.2s;
        user-select: none;
        white-space: nowrap;
      }
      .site-nav__dropdown:hover .site-nav__dropdown-trigger { color: #f59e0b; }
      .site-nav__dropdown-menu {
        display: none;
        position: absolute;
        top: calc(100% + 10px);
        left: 50%;
        transform: translateX(-50%);
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        min-width: 200px;
        padding: 8px 0;
        z-index: 200;
      }
      .site-nav__dropdown:hover .site-nav__dropdown-menu { display: block; }
      .site-nav__dropdown-menu a {
        display: block;
        padding: 9px 18px;
        font-size: 0.85rem;
        color: #333;
        white-space: nowrap;
        border-radius: 0;
      }
      .site-nav__dropdown-menu a:hover {
        background: #fffbeb;
        color: #d97706;
      }

      /* メイン */
      .site-main {
        flex: 1;
        max-width: 1080px;
        margin: 0 auto;
        padding: 32px 20px;
        width: 100%;
      }

      /* フッター */
      .site-footer {
        background: #1a1a1a;
        color: #aaa;
        margin-top: auto;
      }
      .site-footer__inner {
        max-width: 1080px;
        margin: 0 auto;
        padding: 32px 20px;
      }
      .site-footer__top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        margin-bottom: 20px;
      }
      .site-footer__logo {
        font-size: 1.2rem;
        font-weight: 900;
        color: #fff;
        text-decoration: none;
      }
      .site-footer__logo span { color: #f59e0b; }
      .site-footer__nav {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
      }
      .site-footer__nav a {
        font-size: 0.85rem;
        text-decoration: none;
        color: #aaa;
        transition: color 0.2s;
      }
      .site-footer__nav a:hover { color: #fff; }
      .site-footer__bottom {
        border-top: 1px solid #333;
        padding-top: 16px;
        font-size: 0.8rem;
        text-align: center;
        line-height: 1.6;
        color: #666;
      }

      /* ── ハンバーガーボタン ── */
      .hamburger {
        display: none;
        flex-direction: column;
        justify-content: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        border-radius: 6px;
        transition: background 0.2s;
      }
      .hamburger:hover { background: #fef3c7; }
      .hamburger__bar {
        display: block;
        width: 22px;
        height: 2px;
        background: #333;
        border-radius: 2px;
        transition: transform 0.3s, opacity 0.3s;
      }
      /* 開いた時のX変形 */
      .hamburger.is-open .hamburger__bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .hamburger.is-open .hamburger__bar:nth-child(2) { opacity: 0; }
      .hamburger.is-open .hamburger__bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

      /* ── モバイルメニュードロワー ── */
      .mobile-menu {
        display: none;
        position: fixed;
        top: 63px; /* header高さ分 */
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 99;
      }
      .mobile-menu.is-open { display: block; }
      .mobile-menu__overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.4);
      }
      .mobile-menu__panel {
        position: absolute;
        top: 0;
        right: 0;
        width: 75%;
        max-width: 280px;
        height: 100%;
        background: #fff;
        overflow-y: auto;
        box-shadow: -4px 0 20px rgba(0,0,0,0.15);
        padding: 0 0 40px;
      }
      .mobile-menu__section {
        padding: 12px 0;
        border-bottom: 1px solid #f3f4f6;
      }
      .mobile-menu__section-title {
        display: block;
        padding: 6px 20px;
        font-size: 0.72rem;
        font-weight: 700;
        color: #f59e0b;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .mobile-menu__link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 11px 20px;
        font-size: 0.92rem;
        font-weight: 500;
        color: #333;
        text-decoration: none;
        transition: background 0.15s;
      }
      .mobile-menu__link:hover { background: #fffbeb; color: #d97706; }

      /* レスポンシブ */
      @media (max-width: 640px) {
        .hamburger { display: flex; }
        .site-nav { display: none; } /* デスクトップnavは非表示 */
        .site-main { padding: 20px 14px; }
        .site-footer__top { flex-direction: column; align-items: flex-start; }
      }
    </style>
  </head>
  <body>

    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-logo">Nov<span>lify</span></a>

        <!-- デスクトップ用ナビ -->
        <nav class="site-nav">
          <a href="/">ホーム</a>
          <div class="site-nav__dropdown">
            <span class="site-nav__dropdown-trigger">カテゴリ ▾</span>
            <div class="site-nav__dropdown-menu">
              <a href="/category/business">💼 副業・ビジネス</a>
              <a href="/category/investment">📈 投資・資産運用</a>
              <a href="/category/travel">✈️ 旅行・観光</a>
              <a href="/category/gourmet">🍜 グルメ・食</a>
              <a href="/category/gadget">🎧 ガジェット・テック</a>
            </div>
          </div>
          <a href="/about">About</a>
          <a href="/contact">お問い合わせ</a>
        </nav>

        <!-- スマホ用ハンバーガーボタン -->
        <button class="hamburger" id="hamburger-btn" aria-label="メニューを開く" aria-expanded="false">
          <span class="hamburger__bar"></span>
          <span class="hamburger__bar"></span>
          <span class="hamburger__bar"></span>
        </button>
      </div>
    </header>

    <!-- スマホ用ドロワーメニュー -->
    <div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true">
      <div class="mobile-menu__overlay" id="menu-overlay"></div>
      <nav class="mobile-menu__panel">
        <div class="mobile-menu__section">
          <a href="/" class="mobile-menu__link">🏠 ホーム</a>
          <a href="/about" class="mobile-menu__link">👤 About</a>
          <a href="/contact" class="mobile-menu__link">✉️ お問い合わせ</a>
        </div>
        <div class="mobile-menu__section">
          <span class="mobile-menu__section-title">カテゴリ</span>
          <a href="/category/business" class="mobile-menu__link">💼 副業・ビジネス</a>
          <a href="/category/investment" class="mobile-menu__link">📈 投資・資産運用</a>
          <a href="/category/travel" class="mobile-menu__link">✈️ 旅行・観光</a>
          <a href="/category/gourmet" class="mobile-menu__link">🍜 グルメ・食</a>
          <a href="/category/gadget" class="mobile-menu__link">🎧 ガジェット・テック</a>
        </div>
      </nav>
    </div>

    <main class="site-main">
      {adsenseId && (
        <div style="margin-bottom:24px;text-align:center;">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-client={adsenseId}
            data-ad-slot="AUTO"
            data-ad-format="auto"
            data-full-width-responsive="true"
          ></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      )}

      <slot />

      {adsenseId && (
        <div style="margin-top:32px;text-align:center;">
          <ins
            class="adsbygoogle"
            style="display:block"
            data-ad-client={adsenseId}
            data-ad-slot="AUTO"
            data-ad-format="auto"
            data-full-width-responsive="true"
          ></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
      )}
    </main>

    <!-- ハンバーガーメニュー開閉スクリプト -->
    <script>
      const btn = document.getElementById('hamburger-btn');
      const menu = document.getElementById('mobile-menu');
      const overlay = document.getElementById('menu-overlay');

      function openMenu() {
        menu?.classList.add('is-open');
        btn?.classList.add('is-open');
        btn?.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      }
      function closeMenu() {
        menu?.classList.remove('is-open');
        btn?.classList.remove('is-open');
        btn?.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      }

      btn?.addEventListener('click', () => {
        btn.classList.contains('is-open') ? closeMenu() : openMenu();
      });
      overlay?.addEventListener('click', closeMenu);

      // メニュー内リンクをタップしたら閉じる
      document.querySelectorAll('.mobile-menu__link').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    </script>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__top">
          <a href="/" class="site-footer__logo">Nov<span>lify</span></a>
          <nav class="site-footer__nav">
            <a href="/about">About</a>
            <a href="/privacy-policy">プライバシーポリシー</a>
            <a href="/disclaimer">免責事項</a>
            <a href="/contact">お問い合わせ</a>
          </nav>
        </div>
        <div class="site-footer__bottom">
          <p>&copy; {new Date().getFullYear()} Novlify. All rights reserved.</p>
          <p>本サイトはアフィリエイト広告を利用しています。</p>
          <p>Amazonのアソシエイトとして、当メディアは適格販売により収入を得ています。</p>
        </div>
      </div>
    </footer>

  </body>
</html>

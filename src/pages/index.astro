---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// アイキャッチ画像を取得（記事本文の最初の画像 or デフォルト）
function getEyecatch(body: string | undefined): string {
  if (!body) return '';
  const m = body.match(/src="(https?:\/\/[^"]+)"/);
  return m ? m[1] : '';
}

const DEFAULT_IMAGES: Record<string, string> = {
  business:   'https://cdn.pixabay.com/photo/2015/01/08/18/29/entrepreneur-593358_1280.jpg',
  investment: 'https://cdn.pixabay.com/photo/2017/09/07/08/54/money-2724241_1280.jpg',
  travel:     'https://cdn.pixabay.com/photo/2016/01/09/18/27/journey-1130732_1280.jpg',
  gourmet:    'https://cdn.pixabay.com/photo/2017/12/09/08/18/pizza-3007395_1280.jpg',
  gadget:     'https://cdn.pixabay.com/photo/2017/05/24/21/33/technology-2341558_1280.jpg',
};

function getDefaultImage(tags: string[]): string {
  const genres = ['business','investment','travel','gourmet','gadget'];
  for (const g of genres) {
    if (tags.some(t => t.toLowerCase().includes(g) || g.includes(t.toLowerCase()))) {
      return DEFAULT_IMAGES[g] || '';
    }
  }
  return DEFAULT_IMAGES.business;
}

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'NEXIGEN',
  url: 'https://nexigen-blog.com',
  description: '副業・投資・旅行・グルメの本音情報ブログ',
};
---

<Layout title="NEXIGEN - 副業・投資・旅行・グルメの本音情報" description="副業・投資・旅行・グルメについての本音・実用情報をお届けします">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </Fragment>

  <!-- ヒーローバナー -->
  <div class="hero">
    <p class="hero__sub">あなたの生活をちょっと豊かにする</p>
    <h1 class="hero__title">NEXIGEN</h1>
    <p class="hero__desc">副業・投資・旅行・グルメの<strong>本音情報</strong>をお届けします</p>
    <div class="hero__tags">
      <span>#副業</span><span>#投資</span><span>#旅行</span><span>#グルメ</span>
    </div>
  </div>

  <!-- カテゴリバッジフィルター（表示のみ） -->
  <div class="section-header">
    <h2 class="section-header__title">最新記事</h2>
    <div class="section-header__line"></div>
    <span class="section-header__count">{posts.length}件</span>
  </div>

  <!-- 記事グリッド -->
  <div class="post-grid">
    {posts.map(post => {
      const eyecatch = getEyecatch(post.body) || getDefaultImage(post.data.tags || []);
      return (
        <article class="post-card">
          <a href={`/blog/${post.id}`} class="post-card__img-wrap">
            <img
              src={eyecatch}
              alt={post.data.title}
              class="post-card__img"
              loading="lazy"
            />
          </a>
          <div class="post-card__body">
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="post-card__tags">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="post-card__tag">{tag}</span>
                ))}
              </div>
            )}
            <a href={`/blog/${post.id}`} class="post-card__title-link">
              <h3 class="post-card__title">{post.data.title}</h3>
            </a>
            <p class="post-card__desc">{post.data.description}</p>
            <div class="post-card__footer">
              <time class="post-card__date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('ja-JP', {year:'numeric',month:'long',day:'numeric'})}
              </time>
              <a href={`/blog/${post.id}`} class="post-card__btn">続きを読む →</a>
            </div>
          </div>
        </article>
      );
    })}
  </div>

</Layout>

<style>
  /* ヒーロー */
  .hero {
    background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%);
    border: 2px solid #fde68a;
    border-radius: 16px;
    padding: 48px 32px;
    text-align: center;
    margin-bottom: 40px;
  }
  .hero__sub {
    color: #92400e;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    margin: 0 0 8px;
  }
  .hero__title {
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 900;
    color: #1a1a1a;
    margin: 0 0 12px;
    letter-spacing: 0.05em;
  }
  .hero__title::after {
    content: '';
    display: block;
    width: 60px;
    height: 4px;
    background: #f59e0b;
    margin: 12px auto 0;
    border-radius: 2px;
  }
  .hero__desc {
    color: #555;
    font-size: 1rem;
    margin: 16px 0;
  }
  .hero__desc strong { color: #d97706; }
  .hero__tags {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  .hero__tags span {
    background: #fff;
    border: 1px solid #fcd34d;
    color: #92400e;
    font-size: 0.8rem;
    font-weight: 700;
    padding: 4px 12px;
    border-radius: 999px;
  }

  /* セクションヘッダー */
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }
  .section-header__title {
    font-size: 1rem;
    font-weight: 900;
    color: #333;
    white-space: nowrap;
    margin: 0;
  }
  .section-header__line {
    flex: 1;
    height: 2px;
    background: #e5e7eb;
  }
  .section-header__count {
    font-size: 0.8rem;
    color: #888;
    white-space: nowrap;
  }

  /* 記事グリッド */
  .post-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
  }

  /* 記事カード */
  .post-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .post-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  }

  /* アイキャッチ */
  .post-card__img-wrap {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .post-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .post-card:hover .post-card__img {
    transform: scale(1.04);
  }

  /* カード本文 */
  .post-card__body {
    padding: 16px 20px 20px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .post-card__tags {
    display: flex;
    gap: 6px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .post-card__tag {
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #92400e;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
  }
  .post-card__title-link { text-decoration: none; }
  .post-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.5;
    margin: 0 0 8px;
    transition: color 0.2s;
  }
  .post-card__title-link:hover .post-card__title { color: #d97706; }
  .post-card__desc {
    font-size: 0.82rem;
    color: #666;
    line-height: 1.6;
    margin: 0 0 16px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .post-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .post-card__date {
    font-size: 0.75rem;
    color: #999;
  }
  .post-card__btn {
    font-size: 0.78rem;
    font-weight: 700;
    color: #f59e0b;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .post-card__btn:hover { color: #d97706; }

  /* モバイル */
  @media (max-width: 640px) {
    .hero { padding: 32px 20px; }
    .post-grid { grid-template-columns: 1fr; gap: 16px; }
  }
</style>

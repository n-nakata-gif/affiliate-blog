---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// 目次用 h2 のみ抽出
const tocItems = headings.filter(h => h.depth === 2);

// ─── ジャンル検出（スラッグのプレフィックスで判定） ───
type Genre = 'investment' | 'business' | 'travel' | 'gadget' | 'gourmet';
const GENRES: Genre[] = ['investment', 'business', 'travel', 'gadget', 'gourmet'];
const genre: Genre = GENRES.find(g => post.id.startsWith(g)) ?? 'business';

// ─── サイドバー用アフィリエイトリンク（ジャンル別 TOP 3） ───
type SidebarLink = { name: string; url: string; desc: string; isAffiliate: boolean };
const SIDEBAR_LINKS: Record<Genre, SidebarLink[]> = {
  investment: [
    { name: "松井証券 iDeCo", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQF+EFRFW2+3XCC+BXIYQ", desc: "節税しながら老後資金を積み立て。手数料無料", isAffiliate: true },
    { name: "DMM株", url: "https://h.accesstrade.net/sp/cc?rk=0100mkk200os2v", desc: "国内手数料最安水準・米国株も取引手数料0円", isAffiliate: true },
    { name: "松井証券（株式）", url: "https://h.accesstrade.net/sp/cc?rk=01000t2p00os2v", desc: "1日50万円まで手数料無料のネット証券", isAffiliate: true },
    { name: "マネックス証券", url: "https://h.accesstrade.net/sp/cc?rk=0100q1bu00os2v", desc: "米国株・NISA対応。業界最低水準の手数料", isAffiliate: true },
    { name: "IOSマネーセミナー", url: "https://af.moshimo.com/af/c/click?a_id=5579374&p_id=1715", desc: "初心者向け無料資産形成セミナー・参加報酬あり", isAffiliate: true },
  ],
  business: [
    { name: "マネーフォワード クラウド", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQJ+5YCTU+4JGQ+614CY", desc: "会計・確定申告をラクに自動化", isAffiliate: true },
    { name: "フジ子さん", url: "https://af.moshimo.com/af/c/click?a_id=5579374&p_id=1472", desc: "必要なときだけ頼めるオンラインアシスタント", isAffiliate: true },
    { name: "ConoHa WING", url: "https://af.moshimo.com/af/c/click?a_id=5579374&p_id=2312", desc: "国内最速・初期費用無料のレンタルサーバー", isAffiliate: true },
  ],
  travel: [
    { name: "じゃらんnet", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQI+DYHVCI+14CS+6C9LD", desc: "全国の宿・ホテルをお得に予約", isAffiliate: true },
    { name: "エアトリプラス（航空券＋ホテル）", url: "https://px.a8.net/svt/ejp?a8mat=4B3UZ9+7FX302+AD2+2NBA8H", desc: "国内航空券＋ホテルをセットでお得に予約", isAffiliate: true },
    { name: "一休.com", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQJ+A2L06Q+1OK+6LHDU", desc: "高級旅館のタイムセールプラン", isAffiliate: true },
    { name: "agoda", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQJ+A36FSI+4X1W+5YRHE", desc: "国内・海外ホテルを最大85%OFF", isAffiliate: true },
  ],
  gourmet: [
    { name: "一休.comレストラン", url: "https://px.a8.net/svt/ejp?a8mat=4B3UZ9+81COS2+1OK+NTRMQ", desc: "最大53%OFF！高級レストランのタイムセール", isAffiliate: true },
    { name: "出前館", url: "https://px.a8.net/svt/ejp?a8mat=4B3UZ9+893BN6+5W08+5YRHE", desc: "日本最大級の加盟店数。今すぐ頼めるフードデリバリー", isAffiliate: true },
    { name: "山内鮮魚店", url: "https://af.moshimo.com/af/c/click?a_id=5579374&p_id=1397", desc: "創業60年・リピート率70%以上の海鮮グルメ通販", isAffiliate: true },
    { name: "ローストビーフたわら屋", url: "https://af.moshimo.com/af/c/click?a_id=5579374&p_id=785", desc: "ギフトにも人気の絶品ローストビーフ専門店", isAffiliate: true },
  ],
  gadget: [
    { name: "Amazon", url: "https://www.amazon.co.jp/?tag=nexigen22-22", desc: "最新ガジェットをお得に購入", isAffiliate: true },
    { name: "ソースネクスト", url: "https://af.moshimo.com/af/c/click?a_id=5579374&p_id=1105", desc: "定番PCソフトが10%以上還元でお得に", isAffiliate: true },
    { name: "DXRacer（ゲーミングチェア）", url: "https://af.moshimo.com/af/c/click?a_id=5579374&p_id=2338", desc: "プロゲーマー愛用のゲーミングチェア専門ブランド", isAffiliate: true },
  ],
};
const currentSidebarLinks = SIDEBAR_LINKS[genre];

// ─── 記事中盤 CTA（目次直後に表示） ───
type MidCta = { text: string; url: string; btnText: string };
const MID_CTA: Record<Genre, MidCta> = {
  investment: { text: "💰 投資デビューするなら、まずは口座開設から。iDeCoで節税しながら老後資金を積み立てよう。", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQF+EFRFW2+3XCC+BXIYQ", btnText: "松井証券 iDeCoを無料で始める →" },
  business:   { text: "📊 副業・フリーランスの会計をかんたんに。確定申告もクラウドで自動化しよう。", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQJ+5YCTU+4JGQ+614CY", btnText: "マネーフォワードを無料で試す →" },
  travel:     { text: "✈️ 旅行費用をもっとお得に。今すぐ宿を比較して早割プランを探そう。", url: "https://px.a8.net/svt/ejp?a8mat=4B3HQI+DYHVCI+14CS+6C9LD", btnText: "じゃらんnetで宿を探す →" },
  gourmet:    { text: "🍽️ 美食をもっとお得に楽しもう。高級レストランが最大53%OFF、今すぐチェック！", url: "https://px.a8.net/svt/ejp?a8mat=4B3UZ9+81COS2+1OK+NTRMQ", btnText: "一休.comレストランでお得プランを探す →" },
  gadget:     { text: "🛒 ガジェットをお得に購入するなら。今すぐ最安値をチェックしよう。", url: "https://www.amazon.co.jp/?tag=nexigen22-22", btnText: "Amazonでガジェットを探す →" },
};
const currentMidCta = MID_CTA[genre];

// アイキャッチ画像（favicon・小アイコン系URLは除外）
const SKIP_IMG = /google\.com\/s2\/favicons|favicon\.ico|\/favicon|[?&]sz=\d{1,2}(&|$)|width=["']\d{1,2}["']|height=["']\d{1,2}["']/;
function getEyecatch(body: string | undefined): string {
  if (!body) return '';
  const htmlRegex = /src="(https?:\/\/[^"]+)"/g;
  let m: RegExpExecArray | null;
  while ((m = htmlRegex.exec(body)) !== null) {
    if (!SKIP_IMG.test(m[0])) return m[1];
  }
  return '';
}
const eyecatch = getEyecatch(post.body);

// OGP 用の絶対 URL 画像（heroImage 優先、相対パスは絶対 URL に変換）
const SITE_ORIGIN = 'https://novlify.jp';
const rawHero = (post.data as any).heroImage as string | undefined;
const ogImageUrl = rawHero
  ? (rawHero.startsWith('http') ? rawHero : `${SITE_ORIGIN}${rawHero}`)
  : eyecatch || undefined;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  url: Astro.url.href,
  image: eyecatch || undefined,
  author: {
    '@type': 'Person',
    '@id': 'https://novlify.jp/about#author',
    name: 'Nori',
    url: 'https://novlify.jp/about',
    jobTitle: '化学系会社員・ブロガー',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Novlify',
    url: 'https://novlify.jp',
  },
};
---

<Layout
  title={`${post.data.title} | Novlify`}
  description={post.data.description}
  image={ogImageUrl}
  canonical={(post.data as any).canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <!-- パンくずリスト -->
  <nav class="breadcrumb" aria-label="パンくずリスト">
    <a href="/">ホーム</a>
    <span class="breadcrumb__sep">›</span>
    <span>{post.data.title}</span>
  </nav>

  <div class="article-layout">

    <!-- メイン記事カラム -->
    <article class="article-card">

      <!-- アイキャッチ -->
      {eyecatch && (
        <div class="article-eyecatch">
          <img src={eyecatch} alt={post.data.title} />
        </div>
      )}

      <!-- ヘッダー情報 -->
      <div class="article-header">
        {post.data.tags && (
          <div class="article-tags">
            {post.data.tags.map(tag => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )}
        <h1 class="article-title">{post.data.title}</h1>
        <div class="article-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            📅 {post.data.pubDate.toLocaleDateString('ja-JP', {year:'numeric',month:'long',day:'numeric'})}
          </time>
          <span class="article-pr-notice">広告・PR含む</span>
        </div>
      </div>

      <!-- 目次（h2が3件以上あるときだけ表示） -->
      {tocItems.length >= 3 && (
        <nav class="toc" aria-label="目次">
          <div class="toc__header">
            <span class="toc__icon">📋</span>
            <span class="toc__label">この記事の目次</span>
            <button class="toc__toggle" aria-label="目次を開閉" onclick="this.closest('.toc').classList.toggle('toc--closed')">▲</button>
          </div>
          <ol class="toc__list">
            {tocItems.map((item, i) => (
              <li class="toc__item">
                <a href={`#${item.slug}`} class="toc__link">
                  <span class="toc__num">{i + 1}</span>
                  {item.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- 記事中盤 CTA（目次直後） -->
      <div class="mid-cta">
        <p class="mid-cta__text">{currentMidCta.text}</p>
        <a href={currentMidCta.url} class="mid-cta__btn" target="_blank" rel="noopener sponsored">
          {currentMidCta.btnText}
        </a>
        <p class="mid-cta__note">※広告・PR含む</p>
      </div>

      <!-- 本文 -->
      <div class="article-body">
        <Content />
      </div>

      <!-- 著者ボックス -->
      <div class="author-box">
        <div class="author-box__avatar">N</div>
        <div class="author-box__body">
          <p class="author-box__name">Nori（のり）</p>
          <p class="author-box__role">化学系会社員 ／ Novlify 運営者</p>
          <p class="author-box__bio">佐賀県在住。化学系の会社に勤める5人家族のパパ。自分の経験をもとに、副業・投資・旅行・ガジェット情報を本音で発信しています。</p>
          <a href="/about" class="author-box__link">プロフィール詳細 →</a>
        </div>
      </div>

      <!-- メール登録バナー -->
      <div class="newsletter-box">
        <div class="newsletter-box__inner">
          <p class="newsletter-box__title">📬 Novlify メルマガ登録（無料）</p>
          <p class="newsletter-box__desc">週1回・副業・投資・ガジェットの厳選情報をお届けします。<br>登録はメールを送るだけ、いつでも解除できます。</p>
          <a
            href={"mailto:info.novlify@gmail.com?subject=%E3%80%90Novlify%E3%83%A1%E3%83%AB%E3%83%9E%E3%82%AC%E7%99%BB%E9%8C%B2%E3%80%91&body=%E3%83%A1%E3%83%AB%E3%83%9E%E3%82%AC%E3%81%AB%E7%99%BB%E9%8C%B2%E3%81%97%E3%81%BE%E3%81%99%E3%80%82%E3%81%9D%E3%81%AE%E3%81%BE%E3%81%BE%E9%80%81%E4%BF%A1%E3%81%97%E3%81%A6%E3%81%8F%E3%81%A0%E3%81%95%E3%81%84%E3%80%82"}
            class="newsletter-box__btn"
          >
            無料でメルマガ登録する →
          </a>
          <p class="newsletter-box__note">※件名・本文はそのままでOKです</p>
        </div>
      </div>

      <!-- 記事フッター -->
      <div class="article-footer">
        <a href="/" class="back-btn">← 記事一覧に戻る</a>
      </div>

    </article>

    <!-- ─── サイドバー（デスクトップのみ表示） ─── -->
    <aside class="sidebar">
      <div class="sidebar-inner">

        <!-- おすすめサービスウィジェット -->
        <div class="sidebar-widget">
          <div class="sidebar-widget__header">🎯 おすすめサービス</div>
          <ul class="sidebar-links">
            {currentSidebarLinks.map(link => (
              <li class="sidebar-link-item">
                <a
                  href={link.url}
                  target="_blank"
                  rel={link.isAffiliate ? "noopener sponsored" : "noopener"}
                  class="sidebar-link"
                >
                  <span class="sidebar-link__name">{link.name}</span>
                  <span class="sidebar-link__desc">{link.desc}</span>
                  <span class="sidebar-link__arrow">→</span>
                </a>
              </li>
            ))}
          </ul>
          <p class="sidebar-widget__pr">※一部PR・広告含む</p>
        </div>

        <!-- 目次ウィジェット -->
        {tocItems.length >= 3 && (
          <div class="sidebar-widget sidebar-toc-widget">
            <div class="sidebar-widget__header">📋 目次</div>
            <ol class="sidebar-toc">
              {tocItems.map((item, i) => (
                <li class="sidebar-toc__item">
                  <a href={`#${item.slug}`} class="sidebar-toc__link">
                    <span class="sidebar-toc__num">{i + 1}</span>
                    <span class="sidebar-toc__text">{item.text}</span>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        )}

      </div>
    </aside>

  </div>

</Layout>

<style>
  /* パンくず */
  .breadcrumb {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: #f59e0b; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb__sep { color: #ccc; }

  /* ─── レイアウト（2カラムグリッド） ─── */
  .article-layout {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 24px;
    align-items: start;
  }
  @media (max-width: 860px) {
    .article-layout {
      grid-template-columns: 1fr;
    }
    .sidebar {
      display: none;
    }
  }

  /* ─── サイドバー ─── */
  .sidebar-inner {
    position: sticky;
    top: 80px;
  }
  .sidebar-widget {
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    overflow: hidden;
    margin-bottom: 20px;
  }
  .sidebar-widget__header {
    background: #f59e0b;
    color: #fff;
    font-weight: 700;
    font-size: 0.82rem;
    padding: 10px 14px;
    letter-spacing: 0.02em;
  }
  .sidebar-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sidebar-link-item {
    border-bottom: 1px solid #f3f4f6;
  }
  .sidebar-link-item:last-child {
    border-bottom: none;
  }
  .sidebar-link {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 2px 6px;
    padding: 12px 14px;
    text-decoration: none;
    transition: background 0.15s;
  }
  .sidebar-link:hover {
    background: #fffbeb;
  }
  .sidebar-link__name {
    grid-column: 1;
    grid-row: 1;
    font-size: 0.82rem;
    font-weight: 700;
    color: #1a1a1a;
    line-height: 1.3;
  }
  .sidebar-link__desc {
    grid-column: 1;
    grid-row: 2;
    font-size: 0.72rem;
    color: #777;
    line-height: 1.4;
  }
  .sidebar-link__arrow {
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
    font-size: 0.75rem;
    color: #f59e0b;
    font-weight: 700;
  }
  .sidebar-widget__pr {
    font-size: 0.68rem;
    color: #aaa;
    text-align: center;
    margin: 0;
    padding: 6px 10px;
    border-top: 1px solid #f3f4f6;
    background: #fafafa;
  }

  /* サイドバー目次 */
  .sidebar-toc {
    list-style: none;
    margin: 0;
    padding: 8px 0;
  }
  .sidebar-toc__item {
    border-bottom: 1px dotted #f3f4f6;
  }
  .sidebar-toc__item:last-child {
    border-bottom: none;
  }
  .sidebar-toc__link {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 8px 14px;
    text-decoration: none;
    font-size: 0.78rem;
    color: #374151;
    line-height: 1.45;
    transition: color 0.15s, background 0.15s;
  }
  .sidebar-toc__link:hover {
    color: #d97706;
    background: #fffbeb;
  }
  .sidebar-toc__num {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: #f59e0b;
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 3px;
  }
  .sidebar-toc__text {
    flex: 1;
    min-width: 0;
  }

  /* ─── 記事中盤 CTA ─── */
  .mid-cta {
    margin: 0 32px 32px;
    background: linear-gradient(135deg, #fef3c7, #fffbeb);
    border: 2px solid #f59e0b;
    border-radius: 14px;
    padding: 22px 24px;
    text-align: center;
  }
  .mid-cta__text {
    font-size: 0.92rem;
    font-weight: 700;
    color: #92400e;
    line-height: 1.65;
    margin: 0 0 14px;
  }
  .mid-cta__btn {
    display: inline-block;
    background: #f59e0b;
    color: #fff;
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.88rem;
    transition: background 0.2s;
    box-shadow: 0 2px 8px rgba(245,158,11,0.35);
  }
  .mid-cta__btn:hover { background: #d97706; }
  .mid-cta__note {
    font-size: 0.68rem;
    color: #b45309;
    margin: 10px 0 0;
  }
  @media (max-width: 640px) {
    .mid-cta { margin: 0 0 24px; }
  }

  /* 記事カード */
  .article-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }

  /* アイキャッチ */
  .article-eyecatch {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .article-eyecatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ヘッダー */
  .article-header {
    padding: 28px 32px 0;
    border-bottom: 2px solid #f3f4f6;
    margin-bottom: 28px;
    padding-bottom: 20px;
  }
  .article-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .article-tag {
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #92400e;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 999px;
  }
  .article-title {
    font-size: clamp(1.2rem, 3.5vw, 1.7rem);
    font-weight: 900;
    color: #111;
    line-height: 1.5;
    margin: 0 0 12px;
  }
  .article-meta {
    font-size: 0.82rem;
    color: #999;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .article-pr-notice {
    font-size: 0.72rem;
    color: #92400e;
    background: #fef3c7;
    border: 1px solid #fde68a;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 600;
  }

  /* 目次 */
  .toc {
    margin: 0 32px 28px;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 12px;
    overflow: hidden;
  }
  .toc__header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: #fef3c7;
    font-weight: 700;

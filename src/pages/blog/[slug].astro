---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// 目次用 h2 のみ抽出
const tocItems = headings.filter(h => h.depth === 2);

// アイキャッチ画像
function getEyecatch(body: string | undefined): string {
  if (!body) return '';
  const m = body.match(/src="(https?:\/\/[^"]+)"/);
  return m ? m[1] : '';
}
const eyecatch = getEyecatch(post.body);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  url: Astro.url.href,
  image: eyecatch || undefined,
  publisher: {
    '@type': 'Organization',
    name: 'Novlify',
    url: 'https://nexigen-blog.com',
  },
};
---

<Layout
  title={`${post.data.title} | Novlify`}
  description={post.data.description}
  image={eyecatch || undefined}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <!-- パンくずリスト -->
  <nav class="breadcrumb" aria-label="パンくずリスト">
    <a href="/">ホーム</a>
    <span class="breadcrumb__sep">›</span>
    <span>{post.data.title}</span>
  </nav>

  <div class="article-layout">

    <!-- メイン記事カラム -->
    <article class="article-card">

      <!-- アイキャッチ -->
      {eyecatch && (
        <div class="article-eyecatch">
          <img src={eyecatch} alt={post.data.title} />
        </div>
      )}

      <!-- ヘッダー情報 -->
      <div class="article-header">
        {post.data.tags && (
          <div class="article-tags">
            {post.data.tags.map(tag => (
              <span class="article-tag">{tag}</span>
            ))}
          </div>
        )}
        <h1 class="article-title">{post.data.title}</h1>
        <div class="article-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            📅 {post.data.pubDate.toLocaleDateString('ja-JP', {year:'numeric',month:'long',day:'numeric'})}
          </time>
        </div>
      </div>

      <!-- 目次（h2が3件以上あるときだけ表示） -->
      {tocItems.length >= 3 && (
        <nav class="toc" aria-label="目次">
          <div class="toc__header">
            <span class="toc__icon">📋</span>
            <span class="toc__label">この記事の目次</span>
            <button class="toc__toggle" aria-label="目次を開閉" onclick="this.closest('.toc').classList.toggle('toc--closed')">▲</button>
          </div>
          <ol class="toc__list">
            {tocItems.map((item, i) => (
              <li class="toc__item">
                <a href={`#${item.slug}`} class="toc__link">
                  <span class="toc__num">{i + 1}</span>
                  {item.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <!-- 本文 -->
      <div class="article-body">
        <Content />
      </div>

      <!-- 記事フッター -->
      <div class="article-footer">
        <a href="/" class="back-btn">← 記事一覧に戻る</a>
      </div>

    </article>

  </div>

</Layout>

<style>
  /* パンくず */
  .breadcrumb {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .breadcrumb a { color: #f59e0b; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb__sep { color: #ccc; }

  /* レイアウト */
  .article-layout {
    max-width: 780px;
    margin: 0 auto;
  }

  /* 記事カード */
  .article-card {
    background: #fff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }

  /* アイキャッチ */
  .article-eyecatch {
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .article-eyecatch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ヘッダー */
  .article-header {
    padding: 28px 32px 0;
    border-bottom: 2px solid #f3f4f6;
    margin-bottom: 28px;
    padding-bottom: 20px;
  }
  .article-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .article-tag {
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #92400e;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 999px;
  }
  .article-title {
    font-size: clamp(1.2rem, 3.5vw, 1.7rem);
    font-weight: 900;
    color: #111;
    line-height: 1.5;
    margin: 0 0 12px;
  }
  .article-meta {
    font-size: 0.82rem;
    color: #999;
  }

  /* 目次 */
  .toc {
    margin: 0 32px 28px;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-radius: 12px;
    overflow: hidden;
  }
  .toc__header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    background: #fef3c7;
    font-weight: 700;
    font-size: 0.9rem;
    color: #92400e;
  }
  .toc__label { flex: 1; }
  .toc__toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.75rem;
    color: #b45309;
    padding: 2px 6px;
    transition: transform 0.2s;
  }
  .toc--closed .toc__toggle { transform: rotate(180deg); }
  .toc--closed .toc__list { display: none; }
  .toc__list {
    margin: 0;
    padding: 12px 16px 16px 20px;
    list-style: none;
  }
  .toc__item { margin: 0; }
  .toc__link {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding: 5px 0;
    text-decoration: none;
    font-size: 0.88rem;
    color: #374151;
    border-bottom: 1px dotted #fde68a;
    transition: color 0.2s;
  }
  .toc__link:hover { color: #d97706; }
  .toc__item:last-child .toc__link { border-bottom: none; }
  .toc__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    background: #f59e0b;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 4px;
    flex-shrink: 0;
  }

  /* 本文 */
  .article-body {
    padding: 0 32px 32px;
  }

  /* 記事フッター */
  .article-footer {
    padding: 20px 32px 28px;
    border-top: 1px solid #f3f4f6;
  }
  .back-btn {
    display: inline-block;
    padding: 10px 20px;
    background: #f59e0b;
    color: #fff;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 700;
    transition: background 0.2s;
  }
  .back-btn:hover { background: #d97706; }

  /* モバイル */
  @media (max-width: 640px) {
    .article-header, .toc { margin-left: 0; margin-right: 0; padding-left: 18px; padding-right: 18px; }
    .toc { margin: 0 0 24px; }
    .article-body { padding: 0 18px 24px; }
    .article-footer { padding: 16px 18px 24px; }
  }
</style>

<style is:global>
  /* ── 記事本文スタイル ── */
  .article-body h2 {
    font-size: 1.2rem;
    font-weight: 900;
    color: #1a1a1a;
    margin: 2.5rem 0 0.875rem;
    padding: 0.6rem 0.875rem;
    border-left: 4px solid #f59e0b;
    background: #fffbeb;
    border-radius: 0 6px 6px 0;
    line-height: 1.5;
  }
  .article-body h3 {
    font-size: 1.05rem;
    font-weight: 700;
    color: #374151;
    margin: 1.75rem 0 0.625rem;
    padding-bottom: 0.375rem;
    border-bottom: 2px dotted #fde68a;
  }
  .article-body h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: #374151;
    margin: 1.25rem 0 0.5rem;
  }
  .article-body p {
    color: #444;
    line-height: 1.9;
    margin: 0 0 1.1rem;
    font-size: 0.95rem;
  }
  .article-body ul,
  .article-body ol {
    color: #444;
    padding-left: 1.5rem;
    margin: 0 0 1.1rem;
    font-size: 0.95rem;
    line-height: 1.85;
  }
  .article-body li { margin-bottom: 0.35rem; }
  .article-body strong { color: #111; font-weight: 700; }
  .article-body em { color: #6b7280; }
  .article-body a {
    color: #d97706;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .article-body a:hover { color: #b45309; }
  .article-body blockquote {
    border-left: 4px solid #f59e0b;
    background: #fffbeb;
    padding: 1rem 1.25rem;
    border-radius: 0 8px 8px 0;
    margin: 1.5rem 0;
    color: #555;
    font-size: 0.92rem;
    line-height: 1.8;
  }
  .article-body blockquote p { margin-bottom: 0.5rem; color: #555; }
  .article-body blockquote p:last-child { margin-bottom: 0; }
  .article-body hr {
    border: none;
    border-top: 2px solid #f3f4f6;
    margin: 2rem 0;
  }
  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }
  .article-body th {
    background: #f59e0b;
    color: #fff;
    font-weight: 700;
    padding: 10px 14px;
    text-align: left;
  }
  .article-body td {
    padding: 9px 14px;
    border-bottom: 1px solid #f3f4f6;
    color: #444;
  }
  .article-body tr:last-child td { border-bottom: none; }
  .article-body tr:nth-child(even) td { background: #fafafa; }
  .article-body code {
    background: #f3f4f6;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.85em;
    color: #d97706;
  }
  .article-body pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: 1.25rem;
    border-radius: 10px;
    overflow-x: auto;
    margin: 1.5rem 0;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .article-body pre code {
    background: none;
    color: inherit;
    padding: 0;
    font-size: inherit;
  }
  .article-body img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }
  .article-body figure { margin: 1.5rem 0; text-align: center; }
  .article-body figcaption { font-size: 0.8em; color: #888; margin-top: 6px; }
  /* 会話ブロック強調 */
  .article-body blockquote strong { color: #d97706; }
</style>
